   "source": [
    "# Churn Prediction Model Training\n",
    "\n",
    "This notebook trains and evaluates ML models for customer churn prediction."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 1,
   "id": "setup",
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "sys.path.insert(0, '..')\n",
    "\n",
    "from pathlib import Path\n",
    "from src.config import PATHS\n",
    "from src.models import ChurnModelTrainer\n",
    "from src.utils import load_or_create_clean_data\n",
    "\n",
    "print(\"Loading and cleaning data...\")\n",
    "df = load_or_create_clean_data()\n",
    "print(f\"Loaded {len(df)} clean records\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "train_model",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "============================================================\n",
      "CHURN PREDICTION MODEL TRAINING PIPELINE\n",
      "============================================================\n"
     ]
    }
   ],
   "source": [
    "# Initialize trainer\n",
    "trainer = ChurnModelTrainer(\n",
    "    data_path=PATHS['clean_data'],\n",
    "    models_dir=PATHS['models']\n",
    ")\n",
    "\n",
    "# Run the full training pipeline\n",
    "result = trainer.run_full_pipeline()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "results",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Display results\n",
    "print(f\"\\nBest Model: {result['best_model']}\")\n",
    "print(f\"\\nMetrics:\")\n",
    "for metric, value in result['metrics'].items():\n",
    "    if metric not in ['model', 'y_pred', 'y_pred_proba']:\n",
    "        print(f\"  {metric}: {value:.4f}\")"
   ]
  }
